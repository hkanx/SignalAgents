{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RetrievalEvalInput",
  "type": "object",
  "required": ["documents", "queries"],
  "properties": {
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_id", "text"],
        "properties": {
          "doc_id": {"type": "string"},
          "text": {"type": "string"}
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query_id", "text", "relevant_doc_ids"],
        "properties": {
          "query_id": {"type": "string"},
          "text": {"type": "string"},
          "relevant_doc_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          }
        }
      }
    }
  }
}
